# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# WARNING: Server-side only. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Use direct connection (port 5432) for migrations
DATABASE_URL=postgresql://postgres.your-ref:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ─── Resend ───────────────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=notifications@yourdomain.com
RESEND_FROM_NAME=Elev8 Comply

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_WEBHOOK_SECRET=generate-a-random-string-here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Elev8 Comply

# ─── Webhook Security ─────────────────────────────────────────────────────────
EMAIL_INTAKE_WEBHOOK_SECRET=generate-a-random-string-here
CRON_SECRET=generate-a-random-string-here

# ─── Direct DB connection (for seed script and migrations) ────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string → Direct
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# This is DIFFERENT from DATABASE_URL which can use the pooler
DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.yourprojectref.supabase.co:5432/postgres
